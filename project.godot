; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Greenside: 3D Golf"
config/version="1.0.0"
config/description="Drag-to-shoot 3D golf over endless procedurally generated holes. Earn points, raid the pro shop for randomized clubs and balls, and chase birdies across changing biomes."
run/main_scene="res://scenes/loading_screen.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/run/main_scene="res://scenes/loading_screen.tscn"
config/icon="res://assets/icon.svg"
boot_splash/bg_color=Color(0.18, 0.55, 0.78, 1)
boot_splash/image="res://assets/splash.png"
boot_splash/fullsize=true
boot_splash/use_filter=true

[autoload]

SaveManager="*res://autoloads/SaveManager.gd"
AudioManager="*res://autoloads/AudioManager.gd"
EquipmentManager="*res://autoloads/EquipmentManager.gd"
GameState="*res://autoloads/GameState.gd"
TournamentManager="*res://autoloads/TournamentManager.gd"
SceneManager="*res://autoloads/SceneManager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[gui]

theme/custom="res://assets/ui/theme.tres"

[rendering]

renderer/rendering_method="mobile"
environment/defaults/default_clear_color=Color(0.18, 0.55, 0.78, 1)
